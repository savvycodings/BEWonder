# Copy to .env and fill in. Never commit real .env.

DATABASE_URL=

# Admin orders (Settings → View orders in the app)
ADMIN_ORDERS_PASSWORD=
ADMIN_JWT_SECRET=

# Peach / EFT checkout (see docs/ARCHITECTURE.md)
PEACH_ENTITY_ID=
PEACH_BEARER_TOKEN=
PEACH_WEBHOOK_SECRET=
PEACH_API_BASE=https://test.oppwa.com

EFT_ACCOUNT_NAME=WonderPort
EFT_ACCOUNT_NUMBER=4116973995
EFT_BANK_NAME=ABSA
EFT_BRANCH_CODE=632005

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# The Courier Guy / ShipLogic (https://sandbox.shiplogic.com/register → Settings → API Keys for sandbox)
# Use the API base URL shown in your ShipLogic portal (production often https://api.portal.thecourierguy.co.za — confirm sandbox host in portal docs).
TCG_ENABLED=false
TCG_API_BASE_URL=
TCG_API_KEY=
# If the portal shows id|secret, we send only the part AFTER "|" as Bearer by default. Use "full" to send the whole TCG_API_KEY, or set TCG_BEARER_TOKEN to exactly what ShipLogic shows for Authorization.
# TCG_API_KEY_BEARER_PART=auto
# TCG_API_KEY_BEARER_PART=full
# TCG_BEARER_TOKEN=
# Optional: append ?account_id= to account-scoped API calls (see Postman “Accounts API”). Must match the account for this API key or you may get 403.
TCG_ACCOUNT_ID=
# Warehouse / collection (JSON). Example: {"type":"business","company":"WonderPort","street_address":"1 Example Rd","local_area":"Suburb","city":"Johannesburg","zone":"GP","country":"ZA","code":"2196"}
TCG_COLLECTION_ADDRESS_JSON=
# JSON: {"name":"Dispatch","mobile_number":"0820000000","email":"dispatch@example.com"}
TCG_COLLECTION_CONTACT_JSON=
TCG_DEFAULT_PARCEL_LENGTH_CM=30
TCG_DEFAULT_PARCEL_WIDTH_CM=25
TCG_DEFAULT_PARCEL_HEIGHT_CM=10
TCG_DEFAULT_PARCEL_WEIGHT_KG=1
# If set, skips POST /rates and uses this code (e.g. ECO). Leave empty to derive from /rates response.
TCG_SERVICE_LEVEL_CODE=
# Pudo locker deliveries: ShipLogic pickup point id (e.g. from pickup-points API). If empty, locker orders use entered_address text instead.
TCG_PUDO_DELIVERY_PICKUP_POINT_ID=
# Sandbox-friendly defaults (see Postman examples).
TCG_MUTE_NOTIFICATIONS=true
TCG_SPECIAL_INSTRUCTIONS_COLLECTION=
TCG_SPECIAL_INSTRUCTIONS_DELIVERY=
# Inbound webhook auth: send header X-Tcg-Webhook-Secret with this value from ShipLogic → Settings → Webhook subscriptions.
TCG_WEBHOOK_SECRET=
